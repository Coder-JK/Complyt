# Complyt Environment Configuration
# Copy this file to .env and adjust values as needed.
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────────
# Path to SQLite database file (relative to apps/web/)
DATABASE_URL=file:./data/complyt.db

# ── Evidence Tools (Optional) ────────────────────────────
# Path to Syft binary for SBOM generation. If unset, Complyt
# generates a basic CycloneDX BOM from package.json/lockfile.
# SYFT_PATH=/usr/local/bin/syft

# ── External API Keys (Optional) ─────────────────────────
# NVD API key for higher rate limits on NVD enrichment.
# Get one free at https://nvd.nist.gov/developers/request-an-api-key
# NVD_API_KEY=

# ── Network Settings ─────────────────────────────────────
# HTTP timeout in milliseconds for external API calls
# HTTP_TIMEOUT_MS=10000

# Max retries for failed HTTP requests
# HTTP_MAX_RETRIES=3

# Set to "true" to force offline mode (use cached data only)
# OFFLINE_MODE=false
